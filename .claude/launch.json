{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Angular)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 4200
    },
    {
      "name": "Backend (Django)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["manage.py", "runserver", "0.0.0.0:8000"],
      "port": 8000
    },
    {
      "name": "Full Stack (docker-compose)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up"],
      "port": 5678
    }
  ]
}
